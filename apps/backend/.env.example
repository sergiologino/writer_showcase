# Скопируйте в .env.local и подставьте свои значения.
# Рабочая директория запуска IDEA / mvnw должна быть apps/backend (тогда файлы ищутся здесь).
# Формат: KEY=value (без кавычек, пробелы вокруг = срезает dotenv)

# DATASOURCE_URL=jdbc:postgresql://localhost:5432/publisher
# DATASOURCE_USERNAME=publisher
# DATASOURCE_PASSWORD=publisher
# JWT_SECRET=замените-на-длинную-случайную-строку
# CORS: для localhost любой порт уже разрешён в application.yml (localhost:*). Для продакшена — publisher.cors в YAML/профиле.
# PUBLIC_SITE_BASE_URL=http://localhost:5173

# Опционально: Redis для очереди публикаций
# PUBLISHER_REDIS_ENABLED=true
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Опционально: внешний сервис ИИ
# AI_INTEGRATION_BASE_URL=
# AI_INTEGRATION_API_KEY=
