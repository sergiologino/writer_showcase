# Скопируйте в .env.local и подставьте свои значения.
# Рабочая директория запуска IDEA / mvnw должна быть apps/backend (тогда файлы ищутся здесь).
# Формат: KEY=value (без кавычек, пробелы вокруг = срезает dotenv)

# DATASOURCE_URL=jdbc:postgresql://localhost:5432/publisher
# DATASOURCE_USERNAME=publisher
# DATASOURCE_PASSWORD=publisher
# JWT_SECRET=замените-на-длинную-случайную-строку
# CORS: для localhost любой порт уже разрешён в application.yml (localhost:*). Для продакшена — publisher.cors в YAML/профиле.
# PUBLIC_SITE_BASE_URL=http://localhost:5173

# Исходящие запросы к Telegram/VK: как у браузера — системный прокси Windows (по умолчанию включено в application.yml).
# PUBLISHER_HTTP_USE_SYSTEM_PROXIES=true
# Если браузер открывает api.telegram.org, а Java — нет, оставьте true. На Linux-сервере без прокси можно false.
# PUBLISHER_HTTP_PREFER_IPV4=false

# Опционально: Redis для очереди публикаций
# PUBLISHER_REDIS_ENABLED=true
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Опционально: внешний сервис ИИ (noteapp-ai-integration)
# Без base-url + api-key вызовы /api/ai/* в Publisher вернут NOT_CONFIGURED или пустой список сетей.
# URL: как в других сервисах — можно задать AI_INTEGRATION_URL; либо AI_INTEGRATION_BASE_URL (имеет приоритет, если задано оба).
# AI_INTEGRATION_URL=https://sergiologino-zettelkastenapp-ai-integration-bce3.twc1.net
# AI_INTEGRATION_BASE_URL=http://localhost:8091
# AI_INTEGRATION_API_KEY=aikey_...
# Синонимы: INTEGRATION_AI_BASE_URL, INTEGRATION_AI_API_KEY
# AI_INTEGRATION_API_KEY_HEADER=X-API-Key
# AI_INTEGRATION_PROCESS_PATH=/api/ai/process
# Список доступных сетей (для GET в интеграции и UI админа)
# AI_INTEGRATION_AVAILABLE_NETWORKS_PATH=/api/ai/networks/available
# AI_INTEGRATION_CONNECT_TIMEOUT_MS=5000
# AI_INTEGRATION_READ_TIMEOUT_MS=120000

# Опционально: создать админа при старте (только dev / первая настройка; не в проде без смены пароля)
# PUBLISHER_ADMIN_BOOTSTRAP_ENABLED=false
# PUBLISHER_ADMIN_BOOTSTRAP_EMAIL=admin@local.test
# PUBLISHER_ADMIN_BOOTSTRAP_PASSWORD=admin
# PUBLISHER_ADMIN_BOOTSTRAP_DISPLAY_NAME=Admin

# Список email с глобальным правом админа (как в других сервисах), через запятую. Дополняет флаг is_admin в БД.
# ADMIN_EMAILS=admin@example.com,other@example.com
