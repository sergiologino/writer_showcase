# Опционально: абсолютный URL бэкенда, если фронт и API на разных origin (без общего /api proxy).
# Пример: VITE_API_BASE_URL=https://api.example.com
# VITE_API_BASE_URL=
# Публичный URL backend для OAuth-переходов /oauth2/authorization/google и /oauth2/authorization/yandex.
# В продакшене задайте явно; dev-дефолт в коде: http://localhost:8080
# VITE_OAUTH_BASE_URL=https://api.example.com
# PUBLIC_SITE_BASE_URL=http://localhost:5173
